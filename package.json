{
  "name": "com.barelysufficient.pels",
  "version": "1.1.1",
  "packageManager": "npm@10.9.4",
  "workspaces": [
    "packages/*"
  ],
  "engines": {
    "node": "22.x",
    "npm": "10.9.4"
  },
  "scripts": {
    "build": "npm run ensure:canvas-arm64 && npm run build:echarts-runtime && tsc && npm run build:settings && npm run sanitize:homey-build",
    "build:echarts-runtime": "node scripts/build-echarts-runtime-bundle.mjs",
    "build:settings": "npm --workspace @pels/settings-ui run build && node scripts/sync-settings-ui.mjs",
    "bench:settings-ui:boot": "node scripts/benchmark-settings-ui-boot.mjs",
    "watch:settings": "npm run build:settings && esbuild packages/settings-ui/src/script.ts --bundle --outfile=settings/script.js --format=iife --target=es2020 --watch",
    "measure:settings-ui:homey": "node scripts/measure-settings-ui-homey.mjs",
    "start": "npm run ensure:canvas-arm64 && npm run build:echarts-runtime && npm run build:settings && homey app run --remote",
    "install-app": "npm run ensure:canvas-arm64 && npm run build:echarts-runtime && npm run build:settings && homey app install",
    "lint": "eslint . --max-warnings=0",
    "lint:runtime": "eslint \"app.ts\" \"api.ts\" \"flowCards/**/*.ts\" \"drivers/**/*.ts\" \"lib/**/*.ts\" --max-warnings=0",
    "lint:css": "stylelint \"packages/settings-ui/public/**/*.css\" --max-warnings=0",
    "lint:html": "html-validate \"packages/settings-ui/public/**/*.html\" --max-warnings=0",
    "arch:check": "dependency-cruiser --config .dependency-cruiser.cjs app.ts flowCards drivers lib packages/settings-ui/src packages/contracts/src packages/shared-domain/src",
    "deadcode:check": "node scripts/check-dead-code.mjs",
    "sanitize:homey-build": "node scripts/sanitize-homey-build.mjs",
    "package:check": "node scripts/check-homey-packaging.mjs",
    "typecheck:unused": "tsc -p tsconfig.runtime-unused.json",
    "test:unit": "jest --config jest.config.fast.cjs",
    "test:unit:ci": "jest --config jest.config.cjs",
    "test:unit:tz": "node scripts/run-timezone-tests.mjs",
    "test:perf": "node --expose-gc ./node_modules/.bin/jest --config jest.config.perf.cjs",
    "ci:checks": "npm run build && npm run lint:css && npm run lint:html && npm run lint:runtime && npm run arch:check && npm run deadcode:check && npm run typecheck:unused && npm run lint",
    "ci:test:runtime": "npm run test:unit:ci && npm run test:unit:tz",
    "ci:test:settings-ui": "npm run test:ui",
    "ci:test:playwright:quick": "npm --workspace @pels/settings-ui run build && CI=1 PELS_E2E_BUILD=0 npm --workspace @pels/settings-ui run test:e2e -- --project=chromium-mobile-width",
    "ci:test:playwright": "npm --workspace @pels/settings-ui run build && CI=1 PELS_E2E_BUILD=0 npm --workspace @pels/settings-ui run test:e2e -- --project=chromium-mobile-width --project=firefox-mobile-width",
    "ci": "npm run ci:checks && npm run ci:test:runtime && npm run ci:test:settings-ui",
    "ci:full": "npm run ci && npm run ci:test:playwright",
    "test": "npm run ci",
    "test:e2e": "npm --workspace @pels/settings-ui run test:e2e",
    "test:ui": "npm --workspace @pels/settings-ui run test",
    "test:all": "npm run ci",
    "validate": "homey app validate && npm run package:check",
    "check": "npm run ci",
    "ensure:canvas-arm64": "node scripts/ensure-canvas-arm64.mjs",
    "ensure:canvas-local": "node scripts/ensure-canvas-local.mjs",
    "start:local": "npm run ensure:canvas-local && npm run build:echarts-runtime && npm run build:settings && homey app run",
    "prepare": "husky"
  },
  "lint-staged": {
    "**/*.ts": [
      "eslint --max-warnings=0 --no-warn-ignored",
      "bash -c 'tsc --noEmit && tsc -p packages/settings-ui/tsconfig.json --noEmit'"
    ],
    "**/*.css": [
      "stylelint --max-warnings=0"
    ],
    "**/*.html": [
      "html-validate --max-warnings=0"
    ]
  },
  "overrides": {
    "eslint-plugin-sonarjs": {
      "minimatch": "10.2.4"
    }
  },
  "dependencies": {
    "@napi-rs/canvas": "^0.1.96",
    "@napi-rs/canvas-linux-x64-gnu": "^0.1.96",
    "homey-api": "^3.16.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.3",
    "@playwright/test": "^1.58.2",
    "@tsconfig/node22": "^22.0.5",
    "@types/homey": "npm:homey-apps-sdk-v3-types@^0.3.12",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.19.15",
    "@types/sortablejs": "^1.15.9",
    "dependency-cruiser": "^17.3.8",
    "echarts": "^6.0.0",
    "esbuild": "^0.27.2",
    "eslint": "^9.39.3",
    "eslint-plugin-functional": "^9.0.2",
    "eslint-plugin-n": "^17.23.2",
    "eslint-plugin-sonarjs": "^4.0.0",
    "eslint-plugin-unicorn": "^63.0.0",
    "globals": "^17.4.0",
    "html-validate": "^10.11.1",
    "husky": "^9.1.7",
    "jest": "^30.2.0",
    "jest-environment-jsdom": "^30.2.0",
    "lint-staged": "^16.3.2",
    "madge": "^8.0.0",
    "puppeteer": "^24.38.0",
    "sortablejs": "^1.15.6",
    "style-dictionary": "^5.3.3",
    "stylelint": "^17.2.0",
    "stylelint-config-recommended": "^18.0.0",
    "tippy.js": "^6.3.7",
    "ts-jest": "^29.4.6",
    "ts-prune": "^0.10.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.53.0"
  },
  "volta": {
    "node": "22.22.0",
    "npm": "10.9.4"
  }
}
