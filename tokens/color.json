        "text": { "value": "{color.base.warning.soft}" }
      },
      "info": {
        "bg": { "value": "color-mix(in srgb, {color.base.info.default} 14%, {color.surface.1})" },
        "border": { "value": "color-mix(in srgb, {color.base.info.default} 55%, {color.surface.3})" },
        "text": { "value": "{color.role.info}" }
      }
    },
