    "shell-nav": {
      "container": {
        "background": { "value": "{pels.surface-container-low}" },
        "border": { "value": "{pels.surface-outline}" },
        "radius": { "value": "{radius.lg}" },
        "padding": { "value": "{spacing.1}" },
        "gap": { "value": "{spacing.1}" }
      },
      "tab": {
        "height": { "value": "{pels.touch-target.min}" },
        "height-compact": { "value": "{pels.touch-target.min}" },
        "padding-inline": { "value": "{spacing.2}" },
        "padding-inline-compact": { "value": "{spacing.1}" },
        "radius": { "value": "{radius.md}" },
        "label-color": { "value": "{pels.text.secondary}" },
        "label-hover-color": { "value": "{pels.text.primary}" },
        "label-size": { "value": "{font.size.sm}" },
        "label-size-compact": { "value": "{font.size.xs}" },
        "label-weight": { "value": "{font.weight.semibold}" },
        "selected-indicator-color": {
          "value": "{color.role.accent}",
          "comment": "M3 underline-indicator colour for the selected nav tab. The selected tab now reads as a modern M3 tab strip — an accent underline bar plus a primary-text label — rather than a filled pill. Accent (brand green) is the canonical M3 active-indicator colour and stays distinct from the tonal segmented-control fill used elsewhere."
        },
        "selected-indicator-height": {
          "value": "3px",
          "comment": "M3 primary-tab active-indicator thickness (3 px is the Material 3 spec value). Literal px — there is no 3 px spacing step and the indicator is a fixed hairline bar, not layout spacing, so it is encoded directly at the token layer."
        },
        "selected-background": {
          "value": "transparent",
          "comment": "The selected nav tab no longer fills a pill — it uses the M3 underline indicator (`selected-indicator-color`) plus a primary-text label, so the tab container stays transparent (the base `.tabs` rule already paints no container fill). Retained as the documented selected-state anchor for the strip; the layout test pins it to `transparent` to guard against a pill regression, and the `selected-hover-background` sibling is still consumed by `.plan-chip--link` hover."
        },
        "selected-hover-background": {
          "value": "rgba({color.base.accent.default-rgb}, 0.38)",
          "comment": "Tonal accent-tint hover fill. No longer used by the nav tab (which is underline-only) but still consumed by `.plan-chip--link[aria-pressed=true]:hover`, so the token stays."
        },
        "selected-text": { "value": "{pels.text.primary}" }
      }
    },
    "control-track-3x": {
      "value": "144px",
      "comment": "Three touch-target slots wide. Encoded as the absolute px value because Style Dictionary cannot resolve a calc against another token at build time; keep in sync with pels.touch-target.min (currently 48 px) so this stays equal to 3 * pels.touch-target.min."
    },
    "deadline-close": {
