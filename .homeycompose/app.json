  },
  "brandColor": "#22c55e",
  "category": [
    "energy",
    "climate"
  ],
  "source": "https://github.com/olemarkus/com.barelysufficient.pels",
  "homeyCommunityTopicId": 147496,
  "homepage": "https://pels.barelysufficient.org/",
  "support": "mailto:olemarkus@gmail.com",
  "bugs": {
    "url": "https://github.com/olemarkus/com.barelysufficient.pels/issues"
  },
  "tags": {
    "en": [
      "power limit",
      "peak shaving",
      "EV charging",
      "water heater",
      "cheap hours",
      "dynamic prices",
      "capacity tariff",
      "Homey Energy",
      "Tibber Pulse",
      "HAN",
      "floor heating"
    ],
    "no": [
      "effektledd",
      "kapasitetsledd",
      "nettleie",
      "elbillader",
      "elbillading",
      "varmtvannsbereder",
      "billige timer",
      "strømpris",
      "Norgespris",
      "strømstøtte",
      "Tibber Pulse",
      "AMS",
      "HAN",
      "gulvvarme"
    ]
  },
  "permissions": [
    "homey:manager:api"
  ],
  "api": {
    "ui_bootstrap": {
      "method": "GET",
      "path": "/ui_bootstrap"
    },
    "ui_devices": {
      "method": "GET",
      "path": "/ui_devices"
    },
    "ui_plan": {
      "method": "GET",
      "path": "/ui_plan"
    },
    "ui_power": {
      "method": "GET",
      "path": "/ui_power"
    },
    "ui_prices": {
      "method": "GET",
      "path": "/ui_prices"
    },
    "ui_device_diagnostics": {
      "method": "GET",
      "path": "/ui_device_diagnostics"
    },
    "ui_deferred_objective_history": {
      "method": "GET",
      "path": "/ui_deferred_objective_history"
    },
    "get_daily_budget": {
      "method": "GET",
      "path": "/daily_budget"
    },
    "ui_recompute_daily_budget": {
      "method": "POST",
      "path": "/ui_recompute_daily_budget"
    },
    "ui_preview_daily_budget_model": {
      "method": "POST",
      "path": "/ui_preview_daily_budget_model"
    },
    "ui_apply_daily_budget_model": {
      "method": "POST",
      "path": "/ui_apply_daily_budget_model"
    },
    "ui_refresh_devices": {
      "method": "POST",
      "path": "/ui_refresh_devices"
    },
    "ui_refresh_prices": {
      "method": "POST",
      "path": "/ui_refresh_prices"
    },
    "ui_refresh_grid_tariff": {
      "method": "POST",
      "path": "/ui_refresh_grid_tariff"
    },
    "settings_ui_log": {
      "method": "POST",
      "path": "/settings_ui_log"
    },
    "ui_reset_power_stats": {
      "method": "POST",
      "path": "/ui_reset_power_stats"
    },
    "homey_devices": {
      "method": "GET",
      "path": "/homey_devices"
    },
    "log_homey_device": {
      "method": "POST",
      "path": "/log_homey_device"
    }
  },
  "images": {
    "small": "/assets/images/small.png",
    "large": "/assets/images/large.png",
    "xlarge": "/assets/images/xlarge.png"
