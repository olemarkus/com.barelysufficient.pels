{
  "id": "com.barelysufficient.pels",
  "version": "2.1.14",
  "compatibility": ">=12.4.0",
  "sdk": 3,
  "platforms": [
    "local"
  ],
  "name": {
    "en": "PELS"
  },
  "description": {
    "en": "Save energy and money with automatic capacity control and price-aware load shifting."
  },
  "brandColor": "#7fd1ae",
  "category": [
    "energy",
    "climate"
  ],
  "source": "https://github.com/olemarkus/com.barelysufficient.pels",
  "homeyCommunityTopicId": 147496,
  "homepage": "https://pels.barelysufficient.org/",
  "support": "mailto:olemarkus@gmail.com",
  "bugs": {
    "url": "https://github.com/olemarkus/com.barelysufficient.pels/issues"
  },
  "tags": {
    "en": [
      "capacity",
      "power limit",
      "energy price",
      "temperature",
      "spot price",
      "grid tariff",
      "energy optimization",
      "power management"
    ]
  },
  "permissions": [
    "homey:manager:api"
  ],
  "api": {
    "ui_bootstrap": {
      "method": "GET",
      "path": "/ui_bootstrap"
    },
    "ui_devices": {
      "method": "GET",
      "path": "/ui_devices"
    },
    "ui_plan": {
      "method": "GET",
      "path": "/ui_plan"
    },
    "ui_power": {
      "method": "GET",
      "path": "/ui_power"
    },
    "ui_prices": {
      "method": "GET",
      "path": "/ui_prices"
    },
    "ui_device_diagnostics": {
      "method": "GET",
      "path": "/ui_device_diagnostics"
    },
    "get_daily_budget": {
      "method": "GET",
      "path": "/daily_budget"
    },
    "ui_refresh_devices": {
      "method": "POST",
      "path": "/ui_refresh_devices"
    },
    "ui_refresh_prices": {
      "method": "POST",
      "path": "/ui_refresh_prices"
    },
    "ui_refresh_grid_tariff": {
      "method": "POST",
      "path": "/ui_refresh_grid_tariff"
    },
    "settings_ui_log": {
      "method": "POST",
      "path": "/settings_ui_log"
    },
    "ui_reset_power_stats": {
      "method": "POST",
      "path": "/ui_reset_power_stats"
    },
    "homey_devices": {
      "method": "GET",
      "path": "/homey_devices"
    },
    "log_homey_device": {
      "method": "POST",
      "path": "/log_homey_device"
    }
  },
  "images": {
    "small": "/assets/images/small.png",
    "large": "/assets/images/large.png",
    "xlarge": "/assets/images/xlarge.png"
  },
  "author": {
    "name": "Ole Markus With",
    "email": "olemarkus@gmail.com"
  },
  "contributing": {
    "donate": {
      "githubSponsors": {
        "username": "olemarkus"
      }
    }
  }
}