          {
            "name": "power_w",
            "type": "text",
            "title": {
              "en": "Power"
            },
            "placeholder": {
              "en": "1750 or 1750 W"
            }
          }
        ],
        "id": "report_stepped_load_power"
      },
      {
        "title": {
          "en": "Set capacity limit"
        },
        "titleFormatted": {
          "en": "Set capacity limit to [[limit_kw]] kW"
        },
