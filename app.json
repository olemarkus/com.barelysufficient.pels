        },
        "hint": {
          "en": "Feed instantaneous power (W) from a meter to track hourly energy usage and feed capacity guard."
        },
        "args": [
          {
            "name": "power",
            "type": "number",
            "title": {
              "en": "Power (W)"
            },
            "min": 0,
            "step": 1
          }
        ],
        "id": "report_power_usage"
      },
      {
        "title": {
          "en": "Report stepped load"
        },
        "titleFormatted": {
          "en": "Report stepped load for [[device]] as [[step]]"
