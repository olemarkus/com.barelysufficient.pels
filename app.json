  "flow": {
    "triggers": [
      {
        "title": {
          "en": "Capacity guard: manual action needed"
        },
        "titleFormatted": {
          "en": "Capacity guard predicts hourly hard-cap budget breach; manual action required"
        },
        "args": [],
        "hint": {
          "en": "Triggers when PELS projects that the hourly hard-cap budget will be breached at the current run rate and there are no controllable devices left to shed. This is an emergency situation requiring immediate manual intervention. Note: This only triggers for hourly hard-cap budget breaches, never for daily budget soft-limit violations."
        },
        "id": "capacity_shortfall"
      },
      {
