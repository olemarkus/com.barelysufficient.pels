            "placeholder": {
              "en": "Select stepped-load device"
            }
          },
          {
            "name": "step",
            "type": "autocomplete",
            "title": {
              "en": "Step"
            },
            "placeholder": {
              "en": "Select step"
            }
          }
        ],
        "id": "report_stepped_load_actual_step"
      },
      {
        "title": {
          "en": "Report stepped load"
        },
        "titleFormatted": {
          "en": "Report stepped load for [[device]] matching [[power_w]]"
