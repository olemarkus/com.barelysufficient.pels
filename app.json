  "flow": {
    "triggers": [
      {
        "title": {
          "en": "Capacity guard: manual action needed"
        },
        "titleFormatted": {
          "en": "Capacity guard predicts hourly hard cap breach; manual action needed"
        },
        "args": [],
        "hint": {
          "en": "Triggers when PELS projects that the hourly hard cap will be breached at the current run rate and there are no managed devices left to limit. This is an emergency situation requiring immediate manual intervention. Note: This only triggers for hourly hard cap breaches, never for daily budget violations."
        },
        "id": "capacity_shortfall"
      },
      {
        "title": {
          "en": "Smart task ended"
        },
        "titleFormatted": {
          "en": "Smart task ended for [[device]]"
        },
        "hint": {
          "en": "Fires once when a smart task run concludes — succeeded (target reached and held), missed (ready-by time passed below target), or abandoned (cleared by the user or device dropped out for an extended period). Filter on the [[outcome]] tag downstream; values are stable lowercase ids: succeeded / missed / abandoned."
        },
        "args": [
          {
            "name": "device",
            "type": "autocomplete",
            "title": {
              "en": "Device"
            },
            "placeholder": {
              "en": "Select device"
            }
          }
        ],
        "tokens": [
          {
            "name": "device_name",
            "type": "string",
            "title": {
              "en": "Device"
            }
          },
          {
            "name": "outcome",
            "type": "string",
            "title": {
              "en": "Outcome"
            }
          },
          {
