{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "workspaces": {
    ".": {
      "entry": [
        "app.ts",
        "api.ts",
        "drivers/*/device.ts",
        "drivers/*/driver.ts",
        "flowCards/**/*.ts",
        "setup/**/*.ts",
        "scripts/**/*.mjs",
        "test/**/*.test.ts",
        "test/**/*.integration.test.ts"
      ],
      "project": [
        "**/*.{ts,mts,cts}",
        "!packages/**",
        "!widgets/**",
        "!docs/**"
      ]
    },
    "packages/contracts": {
      "entry": [
        "src/**/*.ts"
      ],
      "project": [
        "src/**/*.ts"
      ]
    },
    "packages/shared-domain": {
      "entry": [
        "src/**/*.ts"
      ],
      "project": [
        "src/**/*.ts"
      ]
    },
    "packages/settings-ui": {
      "entry": [
        "test/**/*.test.ts",
        "tests/**/*.spec.ts"
      ],
      "project": [
        "src/**/*.{ts,tsx}"
      ]
    },
    "widgets/*": {
      "entry": [
        "src/**/*.ts"
      ],
      "project": [
        "src/**/*.ts"
      ]
    },
    "docs": {
      "entry": [
        ".vitepress/**/*.{ts,mts}"
      ],
      "project": [
        ".vitepress/**/*.{ts,mts}"
      ]
    }
  },
  "vitest": {
    "config": [
      "vitest.config.mts",
      "vitest.config.unit.mts",
      "vitest.config.integration.mts",
      "vitest.config.e2e.mts",
      "vitest.config.tz.mts"
    ]
  },
  "ignore": [
    "test/mocks/echarts-subpath-shim.ts",
    "test/mocks/homey.ts",
    "vitest-env.d.ts"
  ],
  "ignoreDependencies": [
    "homey",
    "homey-api",
    "playwright"
  ],
  "ignoreBinaries": [
    "homey",
    "zsh"
  ],
  "ignoreExportsUsedInFile": true,
  "rules": {
    "duplicates": "off"
  }
}
