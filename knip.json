{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "workspaces": {
    ".": {
      "entry": [
        "app.ts",
        "api.ts",
        "drivers/*/device.ts",
        "drivers/*/driver.ts",
        "flowCards/**/*.ts",
        "setup/**/*.ts",
        "scripts/**/*.mjs",
        "test/**/*.test.ts",
        "test/**/*.integration.test.ts"
      ],
      "project": ["**/*.{ts,mts,cts}", "!packages/**", "!widgets/**", "!docs/**"]
    },
    "packages/contracts": { "entry": ["src/**/*.ts"], "project": ["src/**/*.ts"] },
    "packages/shared-domain": { "entry": ["src/**/*.ts"], "project": ["src/**/*.ts"] },
    "packages/settings-ui": {
      "entry": ["src/script.ts", "test/**/*.test.ts", "tests/**/*.spec.ts"],
      "project": ["src/**/*.{ts,tsx}"]
    },
    "widgets/*": { "entry": ["src/**/*.ts"], "project": ["src/**/*.ts"] },
    "docs": { "entry": [".vitepress/**/*.{ts,mts}"], "project": [".vitepress/**/*.{ts,mts}"] }
  },
  "ignoreExportsUsedInFile": true
}
