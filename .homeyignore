# Build artifacts not needed at runtime: sourcemaps and type declarations.
# Node never reads .d.ts at runtime, and sourcemaps are pure dead weight
# (socket.io/engine.io/pino ship ~1.3 MB of .map files alone).
**/*.map
**/*.d.ts
